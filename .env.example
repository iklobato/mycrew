# Copy to .env and customize for `task run`
# PIPELINE_TASK is required; others are optional

PIPELINE_TASK=add your task description here

# Required for webhook configuration (configure_webhook_remote.py, register_webhook)
# GITHUB_TOKEN=ghp_xxxx
# GITHUB_WEBHOOK_SECRET=your_secret  # e.g. openssl rand -hex 32

# Optional: Valkey/Redis URL for offloading large pipeline state (exploration, plan, implementation).
# When set, large fields are stored in Valkey instead of in-process memory.
# REDIS_URL=rediss://default:PASSWORD@host:25061
# REPO_PATH=.
# BRANCH=main
# FROM_SCRATCH=false
# MAX_RETRIES=3
# DRY_RUN=false
# TEST_COMMAND=pytest
# ISSUE_ID=
# GITHUB_REPO=
# ISSUE_URL=
# DOCS_URL=
# VERBOSE=false
