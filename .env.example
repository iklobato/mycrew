# Copy to .env and customize for `task run`
# PIPELINE_TASK is required; others are optional

PIPELINE_TASK=add your task description here
# REPO_PATH=.
# BRANCH=main
# FROM_SCRATCH=false
# MAX_RETRIES=3
# DRY_RUN=false
# TEST_COMMAND=pytest
# ISSUE_ID=
# GITHUB_REPO=
# ISSUE_URL=
# DOCS_URL=
# VERBOSE=false
