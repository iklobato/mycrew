# Copy to .env and customize
# Required: issue_url or set in config.yaml

# Required: GitHub token for cloning repos and creating PRs
GITHUB_TOKEN=ghp_xxxx

# Required: LLM API key (from openrouter.ai)
OPENROUTER_API_KEY=your_key

# Optional: Webhook secret for GitHub webhook verification
GITHUB_WEBHOOK_SECRET=your_secret  # e.g. openssl rand -hex 32

# Optional: Serper API key for web search
SERPER_API_KEY=

# Pipeline configuration (can also be set in config.yaml)
# ISSUE_URL=https://github.com/owner/repo/issues/123
# BRANCH=main
# FROM_SCRATCH=false
# MAX_RETRIES=3
# DRY_RUN=false
# PROGRAMMATIC=false

# Logging
# CODE_PIPELINE_LOG_LEVEL=INFO
